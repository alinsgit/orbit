{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orbit",
  "version": "1.4.0",
  "identifier": "com.orbit.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Orbit",
        "width": 1080,
        "height": 940,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost; frame-src http://localhost:* http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "alins",
    "copyright": "Copyright (c) 2026-present alins",
    "category": "DeveloperTool",
    "shortDescription": "Local development environment",
    "longDescription": "Orbit is a modern local development environment. Easily manage Nginx, PHP, MariaDB, Redis and more with a beautiful interface.",
    "licenseFile": "../LICENSE",
    "windows": {
      "certificateThumbprint": null,
      "timestampUrl": null,
      "digestAlgorithm": "sha256",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": [
          "English",
          "Turkish"
        ],
        "displayLanguageSelector": true,
        "startMenuFolder": "Orbit"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4RjE5RTE3ODc2M0I4M0IKUldRN3VHT0hGNTd4R043RFk4YU1OV1BDMGljeXFPejY5WUplU3c4WnQ2THI2d3duZ1RJSXZwT0sK",
      "endpoints": [
        "https://github.com/alinsgit/orbit/releases/latest/download/latest.json"
      ]
    }
  }
}
